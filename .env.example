# Environment variables for wallet-service
# Copy this file to .env and fill in the values

# JWT Configuration
# Secret key for signing JWT tokens. Must be at least 32 characters long.
JWT_SECRET=mySecretKeyForJWT12345678901234567890

# JWT token expiration time in milliseconds (default: 24 hours)
JWT_EXPIRATION_MS=86400000

# Database configuration (optional - defaults to embedded H2)
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/fintech_db;DB_CLOSE_DELAY=-1
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# Server port (optional - defaults to 8081)
# SERVER_PORT=8081

# Logging level (optional)
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG